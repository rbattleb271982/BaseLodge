modules = ["python-3.11", "nodejs-22", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "imagemagick", "sqlite-interactive"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask Server"

[[workflows.workflow]]
name = "Flask Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--workers=2", "app:app"]

[userenv]

[userenv.shared]
FLASK_ENV = "production"
SESSION_COOKIE_SAMESITE = "Lax"
SHOW_IDEAS_DIAGNOSTIC = "false"
ALLOWED_ADMIN_EMAILS = "richardbattlebaxter@gmail.com"
FOUNDER_APP_OPEN_PUSH_ENABLED = "true"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
